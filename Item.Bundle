<script>
 
$(document).ready(function(){
    $('input[name="selling_plan"]').remove();
   $('.ultimate_pack_design_ga_new  kaching-bundle').remove();
 $('.milk-thistile-bundle kaching-bundle').remove();
setTimeout(function(){
 $('.wrapper_bundles_with_subscripton .bundle-box').eq(1).trigger('click');
 
},1000);
  $(document).on('click', '.bundle-box', function () {


    $('.bundle-box').removeClass('active');
    $(this).addClass('active');


    let index = $(this).attr("data_index");
    let var_id = $(this).attr("var_id");
    let var_id_two = $(this).attr("var_id_two");
    let var_id_three = $(this).attr("var_id_three");
 let var_id_four = $(this).attr("var_id_four");
 var qty = $(this).attr('qty');
 var pr =$(this).find('.new').text();
 var com = $(this).find('.old').text();
 $('.main-price').text(pr);
 $('.compare-price').text(com);
    // Set main variant in form
    $('.product-variant-id').val(var_id);

$('.custom_quantity').val(qty);
    // Remove previous bundle items
    $('.bundle-extra').remove();


    // BUNDLE LOGIC
    if (index == "1") {
    
    }


    else if (index == "2") {
        $('.product-form form').append(
            '<input class="bundle-extra" type="hidden" name="items[1][id]" value="'+var_id_two+'">' +
            '<input class="bundle-extra" type="hidden" name="items[1][quantity]" value="1">' 


             
        );
    }


    else if (index == "3") {
        $('.product-form form').append(
            '<input class="bundle-extra" type="hidden" name="items[1][id]" value="'+var_id_two+'">' +
            '<input class="bundle-extra" type="hidden" name="items[1][quantity]" value="1">' +


            '<input class="bundle-extra" type="hidden" name="items[2][id]" value="'+var_id_three+'">' +
            '<input class="bundle-extra" type="hidden" name="items[2][quantity]" value="1">'


            
        );
    }


  });


});






$(document).ready(function () {
  var data_index = '';
$('#subscriptionCheck').prop('checked', true); 
  function toggleSubscription() {


    // Get active bundle index first
    $('.bundle-box.active').each(function () {
      data_index = $(this).attr('data_index'); // or .data('index')
    });


    if ($('#subscriptionCheck').is(':checked')) {


      $('#subscriptionBox').addClass('active');
      $('.wrapper_bundles_with_subscripton').show();
      $('.wrapper_bundles_without_subscripton').hide();


      $('.wrapper_bundles_with_subscripton .bundle-box[data_index="' + data_index + '"]')
        .trigger('click');


    } else {


      $('#subscriptionBox').removeClass('active');
      $('.wrapper_bundles_with_subscripton').hide();
      $('.wrapper_bundles_without_subscripton').show();


      $('.wrapper_bundles_without_subscripton .bundle-box[data_index="' + data_index + '"]')
        .trigger('click');
    }
  }


  // Initial run
  toggleSubscription();


  // On checkbox change
  $('#subscriptionCheck').on('change', function () {
    toggleSubscription();
  });


});


</script>
    <script>
document.addEventListener('DOMContentLoaded', function () {

  // 1. Remove <kaching-bundle> custom element
  document.querySelectorAll('kaching-bundle').forEach(el => el.remove());

  // 2. Remove element with BOTH classes
  document
    .querySelectorAll('.sealsubs-target-element.sealsubs-full')
    .forEach(el => el.remove());

  // 3. Remove selling plan input
  document
    .querySelectorAll('input[name="selling_plan"]')
    .forEach(el => el.remove());

  // 4. Remove kaching bundle property input
  document
    .querySelectorAll('input[name="properties[__kaching_bundles]"]')
    .forEach(el => el.remove());

  // 5. Remove quantity input
  document
    .querySelectorAll('input[name="quantity"]')
    .forEach(el => el.remove());

});
</script>
<script>
(function () {

  function cleanupInjectedElements() {

    // Kaching bundle element
    document.querySelectorAll('kaching-bundle')
      .forEach(el => el.remove());

    // Seal Subscriptions blocks
    document.querySelectorAll(
      '.sealsubs-target-element.sealsubs-full, ' +
      '.sealsubs-target-element.sls-homepage-automatic'
    ).forEach(el => el.remove());

    // Kaching hidden bundle input
    document.querySelectorAll(
      'input[name="properties[__kaching_bundles]"]'
    ).forEach(el => el.remove());

    // Remove ONLY hidden quantity inputs (safe)
    document.querySelectorAll(
      'input[type="hidden"][name="quantity"]'
    ).forEach(el => el.remove());
  }

  // Run once
  cleanupInjectedElements();

  // Observe future DOM injections
  const observer = new MutationObserver(cleanupInjectedElements);

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

})();
</script>


